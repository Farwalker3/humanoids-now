# Resend API Configuration
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Email address that will receive notifications (keep private!)
NOTIFICATION_EMAIL=your-email@example.com

# Vercel KV (Redis) Configuration
# These are automatically set by Vercel when you add KV storage
# Get them from: https://vercel.com/dashboard > Storage > KV
KV_REST_API_URL=your_kv_url
KV_REST_API_TOKEN=your_kv_token
KV_REST_API_READ_ONLY_TOKEN=your_kv_read_only_token

# Optional: From email address (defaults to onboarding@resend.dev in development)
FROM_EMAIL=noreply@yourdomain.com

# Next.js Public URL (optional)
NEXT_PUBLIC_APP_URL=http://localhost:3000
